{
  "name": "@skalfa/skalfa-cli",
  "version": "1.0.5",
  "description": "Command Line Interface tool for scaffolding Skalfa projects, managing extensions, and ejecting core utilities.",
  "main": "dist/bin/skalfa.js",
  "bin": {
    "skalfa": "./dist/bin/skalfa.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node ./dist/bin/skalfa.js",
    "check": "npm run build && node ./dist/bin/skalfa.js --help",
    "prepare": "npm run build"
  },
  "keywords": [
    "aluna",
    "cli",
    "scaffold"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}