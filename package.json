{
  "name": "@skalfa/skalfa-cli",
  "version": "1.0.21",
  "description": "Command Line Interface tool for Skalfa Framework Ecosystem, installation and managing utilities.",
  "license": "MIT",
  "keywords": ["skalfa", "skalfa-cli", "bun-framework"],
  "main": "dist/bin/skalfa.js",
  "bin": {
    "skalfa": "./dist/bin/skalfa.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node build-stubs.js",
    "start": "node ./dist/bin/skalfa.js",
    "check": "npm run build && node ./dist/bin/skalfa.js --help",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@skalfa/skalfa-lang": "file:../skalfa-lang",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
